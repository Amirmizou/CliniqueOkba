# Supabase — base de données des bénéficiaires des organismes conventionnés
# Projet : https://supabase.com/dashboard → Project Settings → API
# NEXT_PUBLIC_SUPABASE_URL : URL du projet (ex: https://xxxx.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY : clé "service_role" — SECRÈTE, serveur uniquement,
#   ne JAMAIS l'exposer côté client. Contourne la RLS.
# Exécuter supabase/schema.sql dans l'éditeur SQL avant la première utilisation.
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Admin Authentication
# STRONGLY PREFERRED: bcrypt hash — if set, plaintext is never checked.
# Generate: node -e "const b=require('bcryptjs'); b.hash('YOUR_PASSWORD',12).then(console.log)"
ADMIN_PASSWORD_HASH=""
# Plaintext fallback — ONLY used when ADMIN_PASSWORD_HASH is not set. Avoid in production.
ADMIN_PASSWORD=""

# NextAuth Secret (REQUIRED FOR PRODUCTION - Generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# NextAuth URL (REQUIRED FOR PRODUCTION)
NEXTAUTH_URL="https://cliniqueokba.vercel.app"

# Google Analytics (Optional)
NEXT_PUBLIC_GA_ID=""

# Contact Information
NEXT_PUBLIC_CONTACT_PHONE="+213 555 123 456"
NEXT_PUBLIC_CONTACT_EMAIL="contact@cliniqueokba.com"

# Emails transactionnels (Resend) — formulaire de contact + notifications bénéficiaires
RESEND_API_KEY=""
# Adresse qui REÇOIT les messages
CLINIC_EMAIL="contact@cliniqueokba.com"
# Adresse EXPÉDITRICE. Tant que le domaine n'est pas vérifié sur resend.com/domains,
# Resend n'envoie qu'à l'adresse du compte. Après vérification :
# MAIL_FROM="Clinique Okba <contact@votre-domaine.com>"
MAIL_FROM="Clinique Okba <onboarding@resend.dev>"

# Base URL (for production)
NEXT_PUBLIC_BASE_URL="https://cliniqueokba.com"

# Google Site Verification (Optional)
GOOGLE_SITE_VERIFICATION=""

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-01-01"
# Token d'écriture (Editor) — requis UNIQUEMENT pour le script de seed (npm run seed)
# À créer sur https://www.sanity.io/manage
SANITY_API_TOKEN=""

# Rate limiting (Optional but RECOMMENDED in production)
# Without these, the limiter falls back to per-instance in-memory counters,
# which cannot enforce a global limit across serverless cold starts/instances.
# Create a free Redis database at https://console.upstash.com and copy the
# REST URL + token from the database's "REST API" section.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
